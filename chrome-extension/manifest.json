{
  "manifest_version": 3,
  "name": "Gridiron Edge ESPN Sync",
  "version": "1.0",
  "description": "Scrapes and synchronizes your active ESPN fantasy league roster and standings with Gridiron Edge.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://fantasy.espn.com/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://fantasy.espn.com/*/draft*",
        "https://fantasy.espn.com/*/draft/draftroom*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
